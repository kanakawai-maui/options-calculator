VITE_API_BASE_URL=http://localhost:4000/api

# Cloudflare Worker URL — used to POST /access/:ticker for hot-ticker tracking
# Set this in Vite build env on Render and locally in client/.env
VITE_CACHE_WORKER_URL=https://yahoo-finance-proxy.rob-b31.workers.dev

# Firebase Auth — get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Firebase Auth — get these from Firebase Console → Project Settings → Your apps → Web app
# Enable Google sign-in: Firebase Console → Authentication → Sign-in method → Google
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
