PORT=4000

# Cloudflare Worker proxy for Yahoo Finance (required on Render free tier)
# Set to your deployed *.workers.dev URL — see cloudflare-worker/wrangler.toml
YAHOO_PROXY_URL=
# Optional: shared secret matching the PROXY_SECRET binding on the CF Worker
YAHOO_PROXY_SECRET=

# D1 option chain cache — set to the same *.workers.dev URL as YAHOO_PROXY_URL
# The server reads cached chains from D1 when live API calls fail.
# Run scripts/prefetch.js locally to populate the cache.
CACHE_WORKER_URL=

# Massive API — backup option chain provider when Yahoo Finance is unavailable
# Requires Options Starter plan ($29/mo) or higher: https://massive.com
# Leave blank (or unset) to skip; synthetic demo data is used as final fallback.
MASSIVE_API_KEY=
